---
import "../styles/tailwind.css";
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Login</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lexend:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-background text-text min-h-screen overflow-hidden bg-stadium">
    <!-- glow -->
    <div class="pointer-events-none fixed left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 rounded-full bg-primary/10 blur-[120px]" />

    <main class="relative z-10 mx-auto flex min-h-screen max-w-container items-center justify-center px-6">
      <div
        class="w-full max-w-md rounded-2xl border border-white/10 bg-surface/60 p-8 shadow-2xl backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-glow"
      >
       

        <!-- header -->
        <div class="mb-8 text-center">
          <h1 class="font-display text-4xl font-extrabold uppercase text-primary">
            Iniciar Sesión
          </h1>

          <p class="mt-3 text-textMuted">
            Accede a tu equipo fantasy del Mundial.
          </p>
        </div>

        <!-- form -->
        <form onsubmit="handleSubmit(event)" class="space-y-6">
          <!-- email -->
          <div class="space-y-2">
            <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
              Email
            </label>

            <input
            name="email"
              type="email"
              placeholder="manager@fantasy.com"
              class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
            />
          </div>

          <!-- password -->
          <div class="space-y-2">
            <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
              Contraseña
            </label>

            <input
              name="password"
              type="password"
              placeholder="••••••••"
              class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
            />
          </div>

          

          <!-- button -->
          <button
            type="submit"
            class="w-full rounded-2xl bg-primary px-6 py-4 font-display text-lg font-bold uppercase text-black transition duration-300 hover:-translate-y-0.5 hover:scale-[1.01] hover:shadow-glow active:translate-y-0"
          >
            Entrar
          </button>

          <p
            class="hidden rounded-xl border px-4 py-3 text-sm"
            data-login-message
          ></p>

          <!-- register -->
          <div class="pt-2 text-center">
            <p class="text-sm text-textMuted">
              No tienes cuenta?

              <a
                href="/registro"
                class="ml-1 rounded-md px-1 font-semibold text-accent transition duration-300 hover:bg-accent/10 hover:text-primary hover:opacity-100"
              >
                Registrarse
              </a>
            </p>
          </div>
        </form>
      </div>
    </main>
  </body>

  <script is:inline>
    function showFormMessage(message, type = "error") {
      const element = document.querySelector("[data-login-message]");
      if (!element) return;

      element.textContent = message;
      element.classList.remove(
        "hidden",
        "border-error/30",
        "bg-error-container/30",
        "text-on-error-container",
        "border-primary/30",
        "bg-primary-container/30",
        "text-primary",
      );

      if (type === "error") {
        element.classList.add(
          "border-error/30",
          "bg-error-container/30",
          "text-on-error-container",
        );
        return;
      }

      element.classList.add(
        "border-primary/30",
        "bg-primary-container/30",
        "text-primary",
      );
    }

    async function handleSubmit(event) {
      event.preventDefault();

      const formData = new FormData(event.target);

      const email = formData.get("email");
      const password = formData.get("password");

      const response = await fetch("/api/login", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          email,
          password,
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        console.error("❌ Error en login:", data.error);
        showFormMessage(data.error || "Email o contraseña incorrectos");
        return;
      }

      console.log("✅ Login exitoso");
      console.log("📋 Datos del usuario:", data.user);
      console.log("🔐 Session:", data.session);

      window.location.href = "/dashboard";
    }

    window.handleSubmit = handleSubmit;
  </script>
</html>
