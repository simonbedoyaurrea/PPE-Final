---
import Mercado from "../components/Mercado";
import HomeLayout from "../layout/HomeLayout.astro";
import "../styles/tailwind.css";

import { supabase } from "../lib/supabase";
import { getAuthSession } from "../lib/auth";

export const prerender = false;

const session = await getAuthSession(Astro.cookies);

if (!session.isAuthenticated) {
  return Astro.redirect("/login");
}

const { data: jugadores } = await supabase
  .from("jugadores")
  .select("*");

const { data: nacionalidades } = await supabase
  .from("jugadores")
  .select("nacionalidad");  
---

 

<HomeLayout >
<Mercado jugadores={jugadores} nacionalidades={nacionalidades} client:load/>
</HomeLayout>
