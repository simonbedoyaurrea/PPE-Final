---
import Card from "../components/Card";
import "../styles/tailwind.css";

import { supabase } from "./lib/supabase";

const { data: jugadores } = await supabase
  .from("jugadores")
  .select("*");
---

 
<html class="dark" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Mercado de Fichajes | World Cup Fantasy</title>
 
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lexend:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
 
    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
      }
 
      ::-webkit-scrollbar {
        width: 8px;
      }
 
      ::-webkit-scrollbar-track {
        background: #121414;
      }
 
      ::-webkit-scrollbar-thumb {
        background: #404944;
        border-radius: 4px;
      }
 
      ::-webkit-scrollbar-thumb:hover {
        background: #95d3ba;
      }
    </style>
  </head>
 
  <body class="bg-background text-on-surface min-h-screen flex selection:bg-primary selection:text-on-primary ">
    <!-- Desktop SideNavBar -->
    <nav class="hidden md:flex flex-col shrink-0 bg-surface-container dark:bg-surface-container-lowest h-screen w-64 fixed left-0 top-0 z-40 bg-surface-container/40 backdrop-blur-lg border-r border-outline-variant/20 shadow-xl gap-unit py-margin">
      <div class="px-margin mb-8">
        <div class="flex items-center gap-4 mb-2">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-tertiary-fixed-dim">
            <img
              alt="National Team Crest"
              class="w-full h-full object-cover"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6pPmaxSPTrw4yxLT1SUL8NFuJ7BzookcDBU6C-XC-WSt1vLXNRN8TV3A4OxrfXcIaJfzzq3z-On54HKzwEmQX-K8ORnh9cZYn_2rXRrXTE0IoIaVzGlKh8l0ymU1XUfscPF8s5PB08qCNi1_RFTu4H5MVdLCH4A9SjmyUdyRgG7HHVRCGueT_rU1VmMKF8X-54luxsbe5Y2MJ5I4E-eHLm4bkhCeif8mQj6AirjeINZO4trlSiDupPXeWw5VXcWg43Awqvtwf2Zk"
            />
          </div>
 
          <div>
            <h2 class="font-headline-md text-headline-md text-on-surface">
              Global Command
            </h2>
            <p class="font-body-md text-body-md text-on-surface-variant">
              Elite Manager
            </p>
          </div>
        </div>
 
        <button class="w-full mt-4 bg-primary text-on-primary-fixed font-label-bold text-label-bold py-3 skew-x-[-5deg] hover:skew-x-0 transition-transform duration-300 relative overflow-hidden group">
          <div class="absolute inset-0 bg-white/20 w-full -translate-x-full group-hover:translate-x-full transition-transform duration-500 ease-in-out"></div>
          <span class="skew-x-[5deg] block">Build Squad</span>
        </button>
      </div>
 
      <ul class="flex-1 overflow-y-auto w-full">
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-[0deg] transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">dashboard</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Dashboard
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="bg-primary-container text-on-primary-container rounded-lg flex items-center gap-4 px-4 py-3 mx-2 skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">storefront</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Market
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">leaderboard</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Rankings
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">person</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Profile
            </span>
          </a>
        </li>
      </ul>
    </nav>
 
    <!-- Main Content Wrapper -->
    <div class="flex-1 flex flex-col min-h-screen w-full md:pl-64 relative bg-[radial-gradient(ellipse_at_top,var(--tw-gradient-stops))] from-surface-variant/20 via-background to-background">
      <!-- TopAppBar -->
      <header class="top-0 sticky z-50 border-b border-outline-variant/30 bg-background/40 backdrop-blur-md shadow-2xl flex justify-between items-center w-full px-margin py-unit h-16">
        <div class="flex items-center gap-margin">
          <span class="text-headline-md font-headline-md font-extrabold uppercase tracking-tighter text-primary dark:text-primary-fixed-dim md:hidden">
            WORLD CUP FANTASY
          </span>
 
          <span class="text-headline-md font-headline-md font-extrabold uppercase tracking-tighter text-primary dark:text-primary-fixed-dim hidden md:block">
            MERCADO
          </span>
        </div>
 
        <div class="flex items-center gap-gutter flex-1 justify-end">
          <div class="hidden md:flex items-center gap-2 bg-surface-container-highest/60 border border-outline-variant/50 px-4 py-1.5 rounded-full backdrop-blur-md shadow-inner">
            <span
              class="material-symbols-outlined text-tertiary-fixed-dim"
              style="font-variation-settings: 'FILL' 1;"
            >
              payments
            </span>
 
            <span class="font-body-md text-body-md text-on-surface-variant">
              Budget:
            </span>
 
            <span class="font-headline-md text-headline-md text-tertiary-fixed-dim">
              $100.0M
            </span>
          </div>
 
          <div class="relative w-full max-w-xs hidden sm:block">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">
              search
            </span>
 
            <input
              class="w-full bg-surface-container/50 border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary rounded-full pl-10 pr-4 py-1.5 text-on-surface font-body-md placeholder:text-on-surface-variant transition-all duration-300"
              placeholder="Search players..."
              type="text"
            />
          </div>
 
          <div class="flex items-center gap-2">
            <button class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant font-medium hover:text-primary transition-colors duration-300 cursor-pointer active:scale-95">
              <span class="material-symbols-outlined">notifications</span>
            </button>
 
            <button class="w-10 h-10 flex items-center justify-center rounded-full text-on-surface-variant font-medium hover:text-primary transition-colors duration-300 cursor-pointer active:scale-95">
              <span class="material-symbols-outlined">settings</span>
            </button>
 
            <div class="w-8 h-8 rounded-full overflow-hidden border border-outline-variant md:hidden ml-2">
              <img
                alt="Manager Avatar"
                class="w-full h-full object-cover"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuDIkmOV0cAuaPVVr4m8uadh8mf3AF-E30m6Bhyn41Ubt0Jyd36pVT1_nbjcUAV7kFBieP2QrqUSiEJYWCgCpFSFwR8xA_2U2zlFqZEWnCchQrq2D4d_PMGZQcOWl0aGL8QNH2qA773XUr00VZM594X2i0ISq50Icb31Or5j2xvELrboNOZNQzgTuaOKzqNSVbRcUaS2TsqogUU6rjDlix951RFDYkYUFoJ0R5iFB2xX60MBagKHcXqaJ7nuFvBamY7eDmm4rD9VOlw"
              />
            </div>
          </div>
        </div>
      </header>
 
      <!-- Canvas Content -->
     <main class="flex-1 px-4 md:px-margin py-margin pb-32 md:pb-margin">
  <div class="max-w-container-max mx-auto flex flex-col lg:flex-row gap-margin">
    
    <!-- Filters Sidebar -->
    <aside class="w-full lg:w-72 shrink-0 self-start sticky top-24">
      
      <div class="bg-surface-variant/30 backdrop-blur-xl border border-outline-variant/20 rounded-2xl p-margin shadow-[0_8px_32px_rgba(0,0,0,0.3)] max-h-[calc(100vh-7rem)] overflow-y-auto">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
          
          <h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">
              tune
            </span>

            Filters
          </h3>

          <button class="font-label-bold text-label-bold text-on-surface-variant hover:text-primary transition-colors">
            RESET
          </button>
        </div>

        <!-- Position Filter -->
        <div class="mb-8">
          
          <label class="font-label-bold text-label-bold text-on-surface-variant block mb-3 uppercase tracking-widest">
            Position
          </label>

          <div class="grid grid-cols-2 gap-2">
            
            <button class="bg-surface-container-highest border border-outline-variant/40 hover:border-primary text-on-surface py-2 rounded-lg skew-x-[-5deg] hover:skew-x-[0deg] transition-all flex justify-center items-center group">
              <span class="skew-x-[5deg] font-label-bold text-label-bold group-hover:text-primary">
                GK
              </span>
            </button>

            <button class="bg-primary/20 border border-primary text-primary py-2 rounded-lg skew-x-[-5deg] hover:skew-x-0 transition-all flex justify-center items-center shadow-[inset_0_0_10px_rgba(149,211,186,0.2)]">
              <span class="skew-x-[5deg] font-label-bold text-label-bold">
                DEF
              </span>
            </button>

            <button class="bg-surface-container-highest border border-outline-variant/40 hover:border-primary text-on-surface py-2 rounded-lg skew-x-[-5deg] hover:skew-x-[0deg] transition-all flex justify-center items-center group">
              <span class="skew-x-[5deg] font-label-bold text-label-bold group-hover:text-primary">
                MID
              </span>
            </button>

            <button class="bg-surface-container-highest border border-outline-variant/40 hover:border-primary text-on-surface py-2 rounded-lg skew-x-[-5deg] hover:skew-x-[0deg] transition-all flex justify-center items-center group">
              <span class="skew-x-[5deg] font-label-bold text-label-bold group-hover:text-primary">
                FWD
              </span>
            </button>
          </div>
        </div>

        <!-- Price Range Filter -->
        <div class="mb-8">
          
          <label class="font-label-bold text-label-bold text-on-surface-variant block mb-3 uppercase tracking-widest">
            Price Range
          </label>

          <div class="flex justify-between font-body-md text-body-md text-on-surface mb-2">
            <span>$4.0M</span>

            <span class="text-tertiary-fixed-dim font-medium">
              $12.5M
            </span>
          </div>

          <div class="relative w-full h-2 bg-surface-container-lowest rounded-full overflow-hidden">
            <div class="absolute left-0 top-0 h-full bg-linear-to-r from-primary to-primary-fixed-dim w-[75%] rounded-full"></div>
          </div>
        </div>

        <!-- Nationality Filter -->
        <div>
          
          <label class="font-label-bold text-label-bold text-on-surface-variant block mb-3 uppercase tracking-widest">
            Nationality
          </label>

          <div class="relative">
            
            <select class="w-full bg-surface-container-highest/50 border border-outline-variant/50 text-on-surface font-body-md rounded-lg pl-4 pr-10 py-2.5 appearance-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors">
              
              <option>All Nations</option>
              <option>Argentina</option>
              <option>Brazil</option>
              <option>France</option>
              <option>England</option>

            </select>

            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">
              expand_more
            </span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Player Grid -->
    <div class="flex-1 min-w-0">
      
      <!-- Sorting Bar -->
      <div class="flex items-center justify-between mb-6 pb-2 border-b border-outline-variant/20">
        
        <span class="font-body-md text-body-md text-on-surface-variant">
          Showing
          <strong class="text-on-surface">
            248
          </strong>
          players
        </span>

        <div class="flex items-center gap-2">
          
          <span class="font-body-md text-body-md text-on-surface-variant hidden sm:inline">
            Sort by:
          </span>

          <select class="bg-transparent border-none text-primary font-label-bold text-label-bold focus:ring-0 cursor-pointer">
            <option>Highest Price</option>
            <option>Total Points</option>
            <option>Form</option>
          </select>
        </div>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-x-gutter gap-y-12 mt-8">
        
        {
          jugadores.map((j) => (
            <Card
              price={j.precio}
              age={j.edad}
              name={j.nombre}
              position={j.posicion}
              club={j.club}
              flag={j.nacionalidad}
              image={j.imagen_url}
              client:load
            />
          ))
        }

      </div>
    </div>
  </div>
</main>
    </div>
 
    <!-- Mobile BottomNavBar -->
    <nav class="md:hidden fixed bottom-0 w-full z-50 h-20 rounded-t-xl bg-surface-container-highest/90 backdrop-blur-2xl border-t-2 border-tertiary-fixed-dim/50 shadow-[0_-10px_30px_rgba(0,0,0,0.5)] left-0 right-0 flex justify-around items-center px-margin bg-linear-to-t from-background to-transparent pb-4">
      <div class="flex flex-col items-center justify-center text-on-surface-variant opacity-80 hover:opacity-100 transition-opacity">
        <span class="material-symbols-outlined mb-1">military_tech</span>
        <span class="font-label-bold text-[10px] whitespace-nowrap">
          Points: 2,450
        </span>
      </div>
 
      <div class="flex flex-col items-center justify-center text-on-surface-variant opacity-80 hover:opacity-100 transition-opacity">
        <span class="material-symbols-outlined mb-1">payments</span>
        <span class="font-label-bold text-[10px] whitespace-nowrap">
          Budget: $100.0M
        </span>
      </div>
 
      <div class="flex flex-col items-center justify-center text-on-surface-variant opacity-80 hover:opacity-100 transition-opacity">
        <span class="material-symbols-outlined mb-1">sports_soccer</span>
        <span class="font-label-bold text-[10px] whitespace-nowrap">
          Active Squad
        </span>
      </div>
 
      <div class="flex flex-col items-center justify-center text-on-surface-variant opacity-80 hover:opacity-100 transition-opacity">
        <span class="material-symbols-outlined mb-1">check_circle</span>
        <span class="font-label-bold text-[10px] whitespace-nowrap">
          Validate Team
        </span>
      </div>
    </nav>
  </body>
</html>