---
import "../styles/tailwind.css";
---

<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mundial Fantasy</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lexend:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen overflow-x-hidden bg-background bg-stadium text-text">
    <header class="mx-auto flex max-w-container items-center justify-between px-6 py-6">
      <a href="/" class="font-display text-2xl font-extrabold uppercase text-primary">
        Mundial Fantasy
      </a>

      <nav class="flex items-center gap-4">
        <a href="/login" class="font-semibold text-textMuted transition hover:text-primary">
          Iniciar sesión
        </a>

        <a
          href="/registro"
          class="rounded-xl bg-primary px-5 py-3 font-display text-sm font-bold uppercase text-black transition hover:shadow-glow"
        >
          Crear cuenta
        </a>
      </nav>
    </header>

    <main>
      <section class="mx-auto flex min-h-[80vh] max-w-container items-center px-6 py-16">
        <div class="max-w-3xl">
          <p class="mb-4 font-display text-sm font-bold uppercase tracking-[0.3em] text-accent">
            Fantasy del Mundial
          </p>

          <h1 class="font-display text-5xl font-extrabold uppercase italic tracking-tight text-primary md:text-7xl">
            Comprá jugadores y armá tu equipo ideal
          </h1>

          <p class="mt-6 max-w-2xl text-lg text-textMuted">
            Crea tu club, usa tu presupuesto, compra jugadores que van al Mundial,
            arma tu once titular y completa tu banquillo para competir contra otros usuarios.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href="/registro"
              class="rounded-2xl bg-primary px-8 py-4 text-center font-display text-lg font-bold uppercase text-black transition hover:scale-[1.01] hover:shadow-glow"
            >
              Empezar ahora
            </a>

            <a
              href="/login"
              class="rounded-2xl border border-outline bg-surface/60 px-8 py-4 text-center font-display text-lg font-bold uppercase text-text transition hover:border-primary"
            >
              Ya tengo cuenta
            </a>
          </div>
        </div>
      </section>

      <section class="mx-auto grid max-w-container gap-6 px-6 pb-20 md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-surface/60 p-6 backdrop-blur-xl">
          <h2 class="font-display text-xl font-bold text-primary">
            Mercado
          </h2>
          <p class="mt-3 text-textMuted">
            Compra jugadores desde la base de datos de Supabase.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-surface/60 p-6 backdrop-blur-xl">
          <h2 class="font-display text-xl font-bold text-primary">
            Presupuesto
          </h2>
          <p class="mt-3 text-textMuted">
            Cada usuario tiene dinero limitado para armar su plantilla.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-surface/60 p-6 backdrop-blur-xl">
          <h2 class="font-display text-xl font-bold text-primary">
            Equipo y banquillo
          </h2>
          <p class="mt-3 text-textMuted">
            Elige titulares y suplentes para completar tu equipo fantasy.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>