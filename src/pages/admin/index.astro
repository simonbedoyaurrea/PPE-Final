---
import HomeLayout from "../../layout/HomeLayout.astro";
import { getAdminSession } from "../lib/adminAuth";
import { supabase } from "../lib/supabase";

export const prerender = false;

const admin = await getAdminSession(Astro.cookies);

if (!admin.isAuthenticated) {
  return Astro.redirect("/login");
}

if (!admin.isAdmin) {
  return Astro.redirect("/dashboard");
}

const { data, error } = await supabase
  .from("jugadores")
  .select("*")
  .order("nombre", { ascending: true });

const jugadores = data ?? [];
const posiciones = [...new Set(jugadores.map((j) => j.posicion).filter(Boolean))];
const nacionalidades = [
  ...new Set(jugadores.map((j) => j.nacionalidad).filter(Boolean)),
];

const precioTotal = jugadores.reduce(
  (total, jugador) => total + Number(jugador.precio || 0),
  0,
);

const mostrar = (valor, fallback = "-") =>
  valor === null || valor === undefined || valor === "" ? fallback : valor;
---

<HomeLayout title="Admin | World Cup Fantasy" active="admin">
  <section class="flex-1 px-4 py-margin pb-32 md:px-margin md:pb-margin">
    <div class="mx-auto flex max-w-container-max flex-col gap-margin">
      <header class="flex flex-col gap-5 border-b border-outline-variant/20 pb-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="mb-2 font-label-bold text-label-bold uppercase tracking-wider text-primary">
            Administracion
          </p>

          <h1 class="font-headline-xl text-4xl font-extrabold uppercase italic leading-tight text-primary md:text-headline-xl">
            Jugadores
          </h1>

          <p class="mt-3 max-w-2xl font-body-lg text-body-lg text-on-surface-variant">
            Vista general de todos los jugadores guardados en la tabla de Supabase.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-3 sm:min-w-[420px]">
          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Total</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">{jugadores.length}</p>
          </div>

          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Paises</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">{nacionalidades.length}</p>
          </div>

          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Valor</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">
              ${precioTotal.toFixed(1)}M
            </p>
          </div>
        </div>
      </header>

      <div class="rounded-xl border border-outline-variant/20 bg-surface-container/40 p-4 shadow-glow backdrop-blur-lg">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center">
          <label class="relative min-w-0 flex-1">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">
              search
            </span>
            <span class="sr-only">Buscar jugador</span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high py-2 pl-10 pr-4 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              data-admin-search
              placeholder="Buscar por nombre, club o nacionalidad..."
              type="search"
            />
          </label>

          <div class="flex flex-col gap-3 sm:flex-row">
            <label class="relative">
              <span class="sr-only">Filtrar por posicion</span>
              <select
                class="w-full appearance-none rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-2 pr-10 text-on-surface outline-none transition focus:ring-1 focus:ring-primary sm:w-44"
                data-position-filter
              >
                <option value="">Todas las posiciones</option>
                {posiciones.map((posicion) => <option value={posicion}>{posicion}</option>)}
              </select>
              <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-outline">
                expand_more
              </span>
            </label>

            <label class="relative">
              <span class="sr-only">Filtrar por nacionalidad</span>
              <select
                class="w-full appearance-none rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-2 pr-10 text-on-surface outline-none transition focus:ring-1 focus:ring-primary sm:w-52"
                data-nationality-filter
              >
                <option value="">Todas las nacionalidades</option>
                {nacionalidades.map((nacionalidad) => (
                  <option value={nacionalidad}>{nacionalidad}</option>
                ))}
              </select>
              <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-outline">
                expand_more
              </span>
            </label>
          </div>
        </div>
      </div>

      <section class="rounded-xl border border-outline-variant/20 bg-surface-container/40 p-6 shadow-2xl backdrop-blur-lg">
        <div class="mb-6 flex flex-col gap-2 border-b border-outline-variant/20 pb-5">
          <p class="font-label-bold text-xs uppercase tracking-widest text-primary">
            Nuevo jugador
          </p>
          <h2 class="font-headline-lg text-2xl font-bold text-on-surface">
            Crear registro
          </h2>
        </div>

        <form class="grid gap-4 md:grid-cols-2 xl:grid-cols-4" data-player-form>
          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Nombre
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              name="nombre"
              placeholder="Lionel Messi"
              required
              type="text"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Posicion
            </span>
            <select
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition focus:border-transparent focus:ring-2 focus:ring-primary"
              name="posicion"
              required
            >
              <option value="">Seleccionar</option>
              <option value="POR">POR</option>
              <option value="DEF">DEF</option>
              <option value="MED">MED</option>
              <option value="DEL">DEL</option>
            </select>
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Club
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              name="club"
              placeholder="Inter Miami"
              type="text"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Nacionalidad
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              name="nacionalidad"
              placeholder="Argentina"
              required
              type="text"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Edad
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              min="0"
              name="edad"
              placeholder="36"
              type="number"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Precio
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              min="0"
              name="precio"
              placeholder="12.5"
              step="0.1"
              type="number"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Goles
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              min="0"
              name="goles"
              placeholder="0"
              type="number"
            />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Asistencias
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              min="0"
              name="asistencias"
              placeholder="0"
              type="number"
            />
          </label>

          <label class="block space-y-2 md:col-span-2 xl:col-span-3">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">
              Imagen URL
            </span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              name="imagen_url"
              placeholder="https://..."
              type="url"
            />
          </label>

          <div class="flex items-end">
            <button
              class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-5 py-3 font-label-bold text-on-primary-fixed transition hover:bg-primary-fixed"
              type="submit"
            >
              <span class="material-symbols-outlined">person_add</span>
              Crear jugador
            </button>
          </div>

          <p class="hidden rounded-lg border px-4 py-3 text-sm md:col-span-2 xl:col-span-4" data-form-message></p>
        </form>
      </section>

      {
        error ? (
          <div class="rounded-xl border border-error/30 bg-error-container/30 p-6 text-on-error-container">
            No se pudieron cargar los jugadores: {error.message}
          </div>
        ) : (
          <section class="overflow-hidden rounded-xl border border-outline-variant/20 bg-surface-container/40 shadow-2xl backdrop-blur-lg">
            <div class="overflow-x-auto">
              <table class="w-full min-w-[1040px] border-collapse text-left">
                <thead class="border-b border-outline-variant/30 bg-surface-container-highest/50">
                  <tr>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Jugador</th>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Nacionalidad</th>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Posicion</th>
                    <th class="px-6 py-4 text-right font-label-bold text-xs uppercase tracking-widest text-primary">Precio</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Edad</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Goles</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Asist.</th>
                  </tr>
                </thead>

                <tbody class="divide-y divide-outline-variant/10">
                  {
                    jugadores.map((jugador) => {
                      const searchText = [
                        jugador.nombre,
                        jugador.club,
                        jugador.nacionalidad,
                        jugador.posicion,
                      ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase();

                      return (
                        <tr
                          class="group transition hover:bg-primary/5"
                          data-admin-row
                          data-nationality={jugador.nacionalidad ?? ""}
                          data-position={jugador.posicion ?? ""}
                          data-search={searchText}
                        >
                          <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                              <div class="relative h-14 w-14 overflow-hidden rounded-lg border border-outline-variant/50 bg-surface-container-highest">
                                {
                                  jugador.imagen_url ? (
                                    <img
                                      alt={`Retrato de ${jugador.nombre}`}
                                      class="h-full w-full object-cover object-top"
                                      src={jugador.imagen_url}
                                    />
                                  ) : (
                                    <div class="flex h-full w-full items-center justify-center text-on-surface-variant">
                                      <span class="material-symbols-outlined">person</span>
                                    </div>
                                  )
                                }
                              </div>

                              <div class="min-w-0">
                                <p class="font-label-bold text-on-surface transition group-hover:text-primary">
                                  {mostrar(jugador.nombre)}
                                </p>
                                <p class="mt-1 text-xs uppercase tracking-wider text-on-surface-variant">
                                  {mostrar(jugador.club, "Sin club")}
                                </p>
                              </div>
                            </div>
                          </td>

                          <td class="px-6 py-4 text-on-surface">
                            {mostrar(jugador.nacionalidad)}
                          </td>

                          <td class="px-6 py-4">
                            <span class="rounded-sm border border-primary/30 bg-primary-container px-3 py-1 font-label-bold text-xs uppercase italic text-primary">
                              {mostrar(jugador.posicion)}
                            </span>
                          </td>

                          <td class="px-6 py-4 text-right">
                            <span class="font-headline-md text-lg font-bold text-tertiary-fixed-dim">
                              ${mostrar(jugador.precio, "0")}M
                            </span>
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.edad)}
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.goles, "0")}
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.asistencias, "0")}
                          </td>
                        </tr>
                      );
                    })
                  }
                </tbody>
              </table>
            </div>

            <div
              class="hidden border-t border-outline-variant/20 p-8 text-center text-on-surface-variant"
              data-empty-state
            >
              No hay jugadores que coincidan con los filtros.
            </div>

            <footer class="flex flex-col gap-4 bg-surface-container-high/40 p-6 sm:flex-row sm:items-center sm:justify-between">
              <span class="text-sm text-on-surface-variant">
                Mostrando <span data-visible-count>{jugadores.length}</span> de {jugadores.length} jugadores
              </span>
            </footer>
          </section>
        )
      }
    </div>
  </section>
</HomeLayout>

<script>
  const searchInput = document.querySelector("[data-admin-search]");
  const positionFilter = document.querySelector("[data-position-filter]");
  const nationalityFilter = document.querySelector("[data-nationality-filter]");
  const rows = [...document.querySelectorAll("[data-admin-row]")];
  const visibleCount = document.querySelector("[data-visible-count]");
  const emptyState = document.querySelector("[data-empty-state]");
  const playerForm = document.querySelector("[data-player-form]");
  const formMessage = document.querySelector("[data-form-message]");

  function mostrarMensaje(message, type = "success") {
    if (!formMessage) return;

    formMessage.textContent = message;
    formMessage.classList.remove(
      "hidden",
      "border-error/30",
      "bg-error-container/30",
      "text-on-error-container",
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );

    if (type === "error") {
      formMessage.classList.add(
        "border-error/30",
        "bg-error-container/30",
        "text-on-error-container",
      );
      return;
    }

    formMessage.classList.add(
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );
  }

  function filtrarJugadores() {
    const search = searchInput?.value.trim().toLowerCase() ?? "";
    const position = positionFilter?.value ?? "";
    const nationality = nationalityFilter?.value ?? "";
    let visible = 0;

    rows.forEach((row) => {
      const matchesSearch = row.dataset.search?.includes(search);
      const matchesPosition = !position || row.dataset.position === position;
      const matchesNationality = !nationality || row.dataset.nationality === nationality;
      const shouldShow = matchesSearch && matchesPosition && matchesNationality;

      row.classList.toggle("hidden", !shouldShow);
      if (shouldShow) visible += 1;
    });

    if (visibleCount) visibleCount.textContent = String(visible);
    emptyState?.classList.toggle("hidden", visible !== 0);
  }

  searchInput?.addEventListener("input", filtrarJugadores);
  positionFilter?.addEventListener("change", filtrarJugadores);
  nationalityFilter?.addEventListener("change", filtrarJugadores);

  playerForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = playerForm.querySelector("button[type='submit']");
    const formData = new FormData(playerForm);
    const payload = Object.fromEntries(formData.entries());

    submitButton.disabled = true;
    submitButton.classList.add("opacity-70", "cursor-wait");
    mostrarMensaje("Creando jugador...");

    try {
      const response = await fetch("/api/admin/jugadores", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (!response.ok) {
        mostrarMensaje(data.error || "No se pudo crear el jugador", "error");
        return;
      }

      mostrarMensaje("Jugador creado correctamente. Actualizando mercado...");
      window.setTimeout(() => {
        window.location.reload();
      }, 700);
    } catch {
      mostrarMensaje("Error de conexion al crear el jugador", "error");
    } finally {
      submitButton.disabled = false;
      submitButton.classList.remove("opacity-70", "cursor-wait");
    }
  });
</script>
