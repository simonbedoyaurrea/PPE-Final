---
import HomeLayout from "../../layout/HomeLayout.astro";
import { getAdminSession } from "../../lib/adminAuth";
import { supabase } from "../../lib/supabase";

export const prerender = false;

const admin = await getAdminSession(Astro.cookies);

if (!admin.isAuthenticated) {
  return Astro.redirect("/login");
}

if (!admin.isAdmin) {
  return Astro.redirect("/dashboard");
}

const { data, error } = await supabase
  .from("jugadores")
  .select("*")
  .order("nombre", { ascending: true });

const jugadores = data ?? [];
const posicionesBase = ["Portero", "Defensa", "Mediocampista", "Delantero"];
const posiciones = [
  ...new Set([
    ...posicionesBase,
    ...jugadores.map((jugador) => jugador.posicion).filter(Boolean),
  ]),
];
const nacionalidades = [
  ...new Set(jugadores.map((jugador) => jugador.nacionalidad).filter(Boolean)),
];

const precioTotal = jugadores.reduce(
  (total, jugador) => total + Number(jugador.precio || 0),
  0,
);

const mostrar = (valor, fallback = "-") =>
  valor === null || valor === undefined || valor === "" ? fallback : valor;

const playerPayload = (jugador) =>
  JSON.stringify({
    id: jugador.id,
    nombre: jugador.nombre ?? "",
    posicion: jugador.posicion ?? "",
    club: jugador.club ?? "",
    nacionalidad: jugador.nacionalidad ?? "",
    edad: jugador.edad ?? 0,
    precio: jugador.precio ?? 0,
    goles: jugador.goles ?? 0,
    asistencias: jugador.asistencias ?? 0,
    imagen_url: jugador.imagen_url ?? "",
  });
---

<HomeLayout title="Admin | World Cup Fantasy" active="admin">
  <section class="flex-1 px-4 py-margin pb-32 md:px-margin md:pb-margin">
    <div class="mx-auto flex max-w-container-max flex-col gap-margin">
      <header class="border-b border-outline-variant/20 pb-6">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="mb-2 font-label-bold text-label-bold uppercase tracking-wider text-primary">
              Administracion
            </p>

            <h1 class="font-headline-xl text-4xl font-extrabold uppercase italic leading-tight text-primary md:text-headline-xl">
              CRUD de jugadores
            </h1>

            <p class="mt-3 max-w-3xl font-body-lg text-body-lg text-on-surface-variant">
              Crea, edita y elimina jugadores del mercado fantasy. Los cambios se guardan en Supabase.
            </p>
          </div>

          <a
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-outline-variant/40 bg-surface-container-high px-5 py-3 font-label-bold text-label-bold text-on-surface transition hover:border-primary hover:text-primary"
            href="/api/admin/debug"
            target="_blank"
          >
            <span class="material-symbols-outlined">bug_report</span>
            Debug admin
          </a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Jugadores</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">{jugadores.length}</p>
          </div>

          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Paises</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">{nacionalidades.length}</p>
          </div>

          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Posiciones</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">{posiciones.length}</p>
          </div>

          <div class="rounded-lg border border-outline-variant/20 bg-surface-container/60 p-4">
            <p class="text-xs uppercase tracking-wider text-on-surface-variant">Valor total</p>
            <p class="mt-1 font-headline-md text-2xl text-primary">
              ${precioTotal.toFixed(1)}M
            </p>
          </div>
        </div>
      </header>

      <section class="rounded-xl border border-outline-variant/20 bg-surface-container/40 p-4 shadow-glow backdrop-blur-lg">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center">
          <label class="relative min-w-0 flex-1">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">
              search
            </span>
            <span class="sr-only">Buscar jugador</span>
            <input
              class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high py-3 pl-10 pr-4 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary"
              data-admin-search
              placeholder="Buscar por nombre, club, nacionalidad o posicion..."
              type="search"
            />
          </label>

          <div class="flex flex-col gap-3 sm:flex-row">
            <label class="relative">
              <span class="sr-only">Filtrar por posicion</span>
              <select
                class="w-full appearance-none rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 pr-10 text-on-surface outline-none transition focus:ring-1 focus:ring-primary sm:w-52"
                data-position-filter
              >
                <option value="">Todas las posiciones</option>
                {posiciones.map((posicion) => <option value={posicion}>{posicion}</option>)}
              </select>
              <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-outline">
                expand_more
              </span>
            </label>

            <label class="relative">
              <span class="sr-only">Filtrar por nacionalidad</span>
              <select
                class="w-full appearance-none rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 pr-10 text-on-surface outline-none transition focus:ring-1 focus:ring-primary sm:w-56"
                data-nationality-filter
              >
                <option value="">Todas las nacionalidades</option>
                {nacionalidades.map((nacionalidad) => (
                  <option value={nacionalidad}>{nacionalidad}</option>
                ))}
              </select>
              <span class="material-symbols-outlined pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-outline">
                expand_more
              </span>
            </label>
          </div>
        </div>
      </section>

      <section class="rounded-xl border border-outline-variant/20 bg-surface-container/40 p-6 shadow-2xl backdrop-blur-lg">
        <div class="mb-6 flex flex-col gap-2 border-b border-outline-variant/20 pb-5">
          <p class="font-label-bold text-xs uppercase tracking-widest text-primary">
            Nuevo jugador
          </p>
          <h2 class="font-headline-lg text-2xl font-bold text-on-surface">
            Crear registro
          </h2>
        </div>

        <form class="grid gap-4 md:grid-cols-2 xl:grid-cols-4" data-player-form>
          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Nombre</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" name="nombre" placeholder="Lionel Messi" required type="text" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Posicion</span>
            <select class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition focus:border-transparent focus:ring-2 focus:ring-primary" name="posicion" required>
              <option value="">Seleccionar</option>
              {posicionesBase.map((posicion) => <option value={posicion}>{posicion}</option>)}
            </select>
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Club</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" name="club" placeholder="Inter Miami" type="text" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Nacionalidad</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" name="nacionalidad" placeholder="Argentina" required type="text" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Edad</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" min="0" name="edad" placeholder="36" type="number" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Precio</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" min="0" name="precio" placeholder="12.5" step="0.1" type="number" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Goles</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" min="0" name="goles" placeholder="0" type="number" />
          </label>

          <label class="block space-y-2">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Asistencias</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" min="0" name="asistencias" placeholder="0" type="number" />
          </label>

          <label class="block space-y-2 md:col-span-2 xl:col-span-3">
            <span class="font-label-bold text-xs uppercase text-on-surface-variant">Imagen URL</span>
            <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none transition placeholder:text-on-surface-variant/70 focus:border-transparent focus:ring-2 focus:ring-primary" name="imagen_url" placeholder="https://..." type="url" />
          </label>

          <div class="flex items-end">
            <button class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-5 py-3 font-label-bold text-on-primary-fixed transition hover:bg-primary-fixed disabled:cursor-wait disabled:opacity-70" type="submit">
              <span class="material-symbols-outlined">person_add</span>
              Crear jugador
            </button>
          </div>

          <p class="hidden rounded-lg border px-4 py-3 text-sm md:col-span-2 xl:col-span-4" data-form-message></p>
        </form>
      </section>

      {
        error ? (
          <div class="rounded-xl border border-error/30 bg-error-container/30 p-6 text-on-error-container">
            No se pudieron cargar los jugadores: {error.message}
          </div>
        ) : (
          <section class="overflow-hidden rounded-xl border border-outline-variant/20 bg-surface-container/40 shadow-2xl backdrop-blur-lg">
            <div class="flex flex-col gap-2 border-b border-outline-variant/20 p-6 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="font-label-bold text-xs uppercase tracking-widest text-primary">
                  Registros
                </p>
                <h2 class="mt-1 font-headline-lg text-2xl font-bold text-on-surface">
                  Jugadores del mercado
                </h2>
              </div>

              <span class="text-sm text-on-surface-variant">
                Mostrando <span data-visible-count>{jugadores.length}</span> de {jugadores.length}
              </span>
            </div>

            <div class="overflow-x-auto">
              <table class="w-full min-w-[1180px] border-collapse text-left">
                <thead class="border-b border-outline-variant/30 bg-surface-container-highest/50">
                  <tr>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Jugador</th>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Nacionalidad</th>
                    <th class="px-6 py-4 font-label-bold text-xs uppercase tracking-widest text-primary">Posicion</th>
                    <th class="px-6 py-4 text-right font-label-bold text-xs uppercase tracking-widest text-primary">Precio</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Edad</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Goles</th>
                    <th class="px-6 py-4 text-center font-label-bold text-xs uppercase tracking-widest text-primary">Asist.</th>
                    <th class="px-6 py-4 text-right font-label-bold text-xs uppercase tracking-widest text-primary">Acciones</th>
                  </tr>
                </thead>

                <tbody class="divide-y divide-outline-variant/10">
                  {
                    jugadores.map((jugador) => {
                      const searchText = [
                        jugador.nombre,
                        jugador.club,
                        jugador.nacionalidad,
                        jugador.posicion,
                      ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase();

                      return (
                        <tr
                          class="group transition hover:bg-primary/5"
                          data-admin-row
                          data-nationality={jugador.nacionalidad ?? ""}
                          data-position={jugador.posicion ?? ""}
                          data-search={searchText}
                        >
                          <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                              <div class="relative h-14 w-14 overflow-hidden rounded-lg border border-outline-variant/50 bg-surface-container-highest">
                                {
                                  jugador.imagen_url ? (
                                    <img
                                      alt={`Retrato de ${jugador.nombre}`}
                                      class="h-full w-full object-cover object-top"
                                      src={jugador.imagen_url}
                                    />
                                  ) : (
                                    <div class="flex h-full w-full items-center justify-center text-on-surface-variant">
                                      <span class="material-symbols-outlined">person</span>
                                    </div>
                                  )
                                }
                              </div>

                              <div class="min-w-0">
                                <p class="font-label-bold text-on-surface transition group-hover:text-primary">
                                  {mostrar(jugador.nombre)}
                                </p>
                                <p class="mt-1 text-xs uppercase tracking-wider text-on-surface-variant">
                                  {mostrar(jugador.club, "Sin club")}
                                </p>
                              </div>
                            </div>
                          </td>

                          <td class="px-6 py-4 text-on-surface">
                            {mostrar(jugador.nacionalidad)}
                          </td>

                          <td class="px-6 py-4">
                            <span class="rounded-sm border border-primary/30 bg-primary-container px-3 py-1 font-label-bold text-xs uppercase italic text-primary">
                              {mostrar(jugador.posicion)}
                            </span>
                          </td>

                          <td class="px-6 py-4 text-right">
                            <span class="font-headline-md text-lg font-bold text-tertiary-fixed-dim">
                              ${mostrar(jugador.precio, "0")}M
                            </span>
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.edad)}
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.goles, "0")}
                          </td>

                          <td class="px-6 py-4 text-center text-on-surface">
                            {mostrar(jugador.asistencias, "0")}
                          </td>

                          <td class="px-6 py-4">
                            <div class="flex justify-end gap-2">
                              <button
                                class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-outline-variant/30 bg-surface-container-high text-on-surface-variant transition hover:border-primary hover:text-primary"
                                data-edit-player={playerPayload(jugador)}
                                title="Editar jugador"
                                type="button"
                              >
                                <span class="material-symbols-outlined text-[20px]">edit</span>
                              </button>

                              <button
                                class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-error/30 bg-error-container/20 text-error transition hover:bg-error-container/40"
                                data-delete-player={jugador.id}
                                data-delete-name={jugador.nombre}
                                title="Eliminar jugador"
                                type="button"
                              >
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                              </button>
                            </div>
                          </td>
                        </tr>
                      );
                    })
                  }
                </tbody>
              </table>
            </div>

            <div
              class="hidden border-t border-outline-variant/20 p-8 text-center text-on-surface-variant"
              data-empty-state
            >
              No hay jugadores que coincidan con los filtros.
            </div>
          </section>
        )
      }
    </div>
  </section>

  <dialog class="fixed inset-0 m-auto max-h-[calc(100vh-32px)] w-[min(720px,calc(100vw-32px))] overflow-y-auto rounded-xl border border-outline-variant/30 bg-surface-container p-0 text-on-surface shadow-2xl backdrop:bg-black/70" data-edit-dialog>
    <form class="grid gap-4 p-6 md:grid-cols-2" data-edit-form>
      <input name="id" type="hidden" />

      <div class="md:col-span-2">
        <p class="font-label-bold text-xs uppercase tracking-widest text-primary">
          Editar jugador
        </p>
        <h2 class="mt-1 font-headline-lg text-2xl font-bold text-on-surface">
          Actualizar registro
        </h2>
      </div>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Nombre</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" name="nombre" required type="text" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Posicion</span>
        <select class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" name="posicion" required>
          {posiciones.map((posicion) => <option value={posicion}>{posicion}</option>)}
        </select>
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Club</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" name="club" type="text" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Nacionalidad</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" name="nacionalidad" required type="text" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Edad</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" min="0" name="edad" type="number" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Precio</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" min="0" name="precio" step="0.1" type="number" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Goles</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" min="0" name="goles" type="number" />
      </label>

      <label class="block space-y-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Asistencias</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" min="0" name="asistencias" type="number" />
      </label>

      <label class="block space-y-2 md:col-span-2">
        <span class="font-label-bold text-xs uppercase text-on-surface-variant">Imagen URL</span>
        <input class="w-full rounded-lg border border-outline-variant/30 bg-surface-container-high px-4 py-3 text-on-surface outline-none focus:ring-2 focus:ring-primary" name="imagen_url" type="url" />
      </label>

      <p class="hidden rounded-lg border px-4 py-3 text-sm md:col-span-2" data-edit-message></p>

      <div class="flex flex-col-reverse gap-3 border-t border-outline-variant/20 pt-4 md:col-span-2 sm:flex-row sm:justify-end">
        <button class="rounded-lg border border-outline-variant/40 px-5 py-3 font-label-bold text-label-bold text-on-surface-variant transition hover:border-primary hover:text-primary" data-close-edit type="button">
          Cancelar
        </button>
        <button class="rounded-lg bg-primary px-5 py-3 font-label-bold text-label-bold text-on-primary-fixed transition hover:bg-primary-fixed disabled:cursor-wait disabled:opacity-70" type="submit">
          Guardar cambios
        </button>
      </div>
    </form>
  </dialog>
</HomeLayout>

<script>
  const searchInput = document.querySelector("[data-admin-search]");
  const positionFilter = document.querySelector("[data-position-filter]");
  const nationalityFilter = document.querySelector("[data-nationality-filter]");
  const rows = [...document.querySelectorAll("[data-admin-row]")];
  const visibleCount = document.querySelector("[data-visible-count]");
  const emptyState = document.querySelector("[data-empty-state]");
  const playerForm = document.querySelector("[data-player-form]");
  const formMessage = document.querySelector("[data-form-message]");
  const editDialog = document.querySelector("[data-edit-dialog]");
  const editForm = document.querySelector("[data-edit-form]");
  const editMessage = document.querySelector("[data-edit-message]");

  function setMessage(element, message, type = "success") {
    if (!element) return;

    element.textContent = message;
    element.classList.remove(
      "hidden",
      "border-error/30",
      "bg-error-container/30",
      "text-on-error-container",
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );

    if (type === "error") {
      element.classList.add(
        "border-error/30",
        "bg-error-container/30",
        "text-on-error-container",
      );
      return;
    }

    element.classList.add(
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );
  }

  function getPayload(form) {
    return Object.fromEntries(new FormData(form).entries());
  }

  async function sendPlayerRequest(method, payload) {
    const response = await fetch("/api/admin/jugadores", {
      method,
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(payload),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "No se pudo completar la operacion");
    }

    return data;
  }

  function filtrarJugadores() {
    const search = searchInput?.value.trim().toLowerCase() ?? "";
    const position = positionFilter?.value ?? "";
    const nationality = nationalityFilter?.value ?? "";
    let visible = 0;

    rows.forEach((row) => {
      const matchesSearch = row.dataset.search?.includes(search);
      const matchesPosition = !position || row.dataset.position === position;
      const matchesNationality = !nationality || row.dataset.nationality === nationality;
      const shouldShow = matchesSearch && matchesPosition && matchesNationality;

      row.classList.toggle("hidden", !shouldShow);
      if (shouldShow) visible += 1;
    });

    if (visibleCount) visibleCount.textContent = String(visible);
    emptyState?.classList.toggle("hidden", visible !== 0);
  }

  searchInput?.addEventListener("input", filtrarJugadores);
  positionFilter?.addEventListener("change", filtrarJugadores);
  nationalityFilter?.addEventListener("change", filtrarJugadores);

  playerForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = playerForm.querySelector("button[type='submit']");
    const payload = getPayload(playerForm);

    submitButton.disabled = true;
    setMessage(formMessage, "Creando jugador...");

    try {
      await sendPlayerRequest("POST", payload);
      setMessage(formMessage, "Jugador creado correctamente. Actualizando tabla...");
      window.setTimeout(() => window.location.reload(), 600);
    } catch (error) {
      setMessage(formMessage, error.message, "error");
    } finally {
      submitButton.disabled = false;
    }
  });

  document.querySelectorAll("[data-edit-player]").forEach((button) => {
    button.addEventListener("click", () => {
      const player = JSON.parse(button.dataset.editPlayer);

      Object.entries(player).forEach(([key, value]) => {
        const input = editForm?.elements.namedItem(key);
        if (input) input.value = value ?? "";
      });

      editMessage?.classList.add("hidden");
      editDialog?.showModal();
    });
  });

  document.querySelector("[data-close-edit]")?.addEventListener("click", () => {
    editDialog?.close();
  });

  editForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = editForm.querySelector("button[type='submit']");
    const payload = getPayload(editForm);

    submitButton.disabled = true;
    setMessage(editMessage, "Guardando cambios...");

    try {
      await sendPlayerRequest("PATCH", payload);
      setMessage(editMessage, "Jugador actualizado. Actualizando tabla...");
      window.setTimeout(() => window.location.reload(), 600);
    } catch (error) {
      setMessage(editMessage, error.message, "error");
    } finally {
      submitButton.disabled = false;
    }
  });

  document.querySelectorAll("[data-delete-player]").forEach((button) => {
    button.addEventListener("click", async () => {
      const playerId = button.dataset.deletePlayer;
      const playerName = button.dataset.deleteName || "este jugador";
      const confirmed = window.confirm(`Eliminar a ${playerName}? Esta accion no se puede deshacer.`);

      if (!confirmed) return;

      button.disabled = true;

      try {
        await sendPlayerRequest("DELETE", { id: playerId });
        window.location.reload();
      } catch (error) {
        alert(error.message);
        button.disabled = false;
      }
    });
  });
</script>
