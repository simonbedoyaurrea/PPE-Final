---
import "../styles/tailwind.css";
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>World Cup Fantasy</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lexend:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-background text-text min-h-screen overflow-x-hidden bg-stadium">
    <!-- Ambient glow -->
    <div
      class="pointer-events-none fixed left-1/2 top-0 z-0 h-[400px] w-[800px] -translate-x-1/2 rounded-full bg-primary/10 blur-[120px]"
    />

    <main class="relative z-10 mx-auto flex min-h-screen max-w-container items-center justify-center px-6 py-10">
      <section class="w-full max-w-3xl">
        <!-- Header -->
        <div class="mb-8 text-center">
          <h1
            class="font-display text-5xl font-extrabold uppercase italic tracking-tight text-primary drop-shadow-lg md:text-6xl"
          >
            Registro
          </h1>
        </div>

        <!-- Card -->
        <div
          class="relative overflow-hidden rounded-3xl border border-white/10 bg-surface/60 p-6 shadow-2xl backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-glow md:p-8"
        >
          <div
            class="absolute left-0 top-0 h-1 w-full bg-gradient-to-r from-transparent via-primary to-transparent opacity-70"
          />

          <form onsubmit="handleSubmit(event)" class="grid gap-5 md:grid-cols-2">
            <!-- names -->
            <div class="space-y-2">
              <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
                Nombre
              </label>

              <input
                name="name"
                type="text"
                placeholder="Pep Guardiola"
                class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
              />
            </div>

            <div class="space-y-2">
              <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
                Nombre Equipo
              </label>

              <input
                name="teamName"
                type="text"
                placeholder="Dream Team FC"
                class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
              />
            </div>

            <!-- email -->
            <div class="space-y-2">
              <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
                Email
              </label>

              <input
                name="email"
                type="email"
                placeholder="manager@fantasy.com"
                class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
              />
            </div>

            <!-- passwords -->
            <div class="space-y-2">
              <label class="text-sm font-semibold uppercase tracking-wide text-textMuted">
                Contraseña
              </label>

              <input
                name="password"
                type="password"
                placeholder="••••••••"
                class="w-full rounded-xl border border-outline bg-background/60 px-4 py-3 outline-none transition duration-300 hover:border-primary/40 hover:bg-background/80 focus:border-primary focus:shadow-[0_0_0_3px_rgba(148,210,189,0.14)]"
              />
            </div>

            <!-- login -->
            <button
              type="submit"
              class="w-full rounded-2xl bg-primary px-6 py-4 font-display text-lg font-bold uppercase text-black transition duration-300 hover:-translate-y-0.5 hover:scale-[1.01] hover:shadow-glow active:translate-y-0 md:col-span-2"
            >
              Crear cuenta
            </button>

            <p
              class="hidden rounded-xl border px-4 py-3 text-sm md:col-span-2"
              data-register-message
            ></p>

            <div class="text-center md:col-span-2">
              <p class="text-sm text-textMuted">
                ¿Ya tienes cuenta?

                <a
                  href="/login"
                  class="rounded-md px-1 font-semibold text-accent transition duration-300 hover:bg-accent/10 hover:text-primary hover:opacity-100"
                >
                  Iniciar sesión
                </a>
              </p>
            </div>
          </form>
        </div>
      </section>
    </main>
  </body>
 <script is:inline>
  function showFormMessage(message, type = "error") {
    const element = document.querySelector("[data-register-message]");
    if (!element) return;

    element.textContent = message;
    element.classList.remove(
      "hidden",
      "border-error/30",
      "bg-error-container/30",
      "text-on-error-container",
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );

    if (type === "error") {
      element.classList.add(
        "border-error/30",
        "bg-error-container/30",
        "text-on-error-container",
      );
      return;
    }

    element.classList.add(
      "border-primary/30",
      "bg-primary-container/30",
      "text-primary",
    );
  }

  async function handleSubmit(event) {
    event.preventDefault();

    const formData = new FormData(event.target);

    const email = formData.get("email");
    const password = formData.get("password");
    const name = formData.get("name");
    const teamName = formData.get("teamName");

    const response = await fetch("/api/registro", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        email,
        password,
        name,
        teamName,
      }),
    });

    const data = await response.json();

    if (!response.ok) {
      showFormMessage(data.error || "Error al crear la cuenta");
      return;
    }

    window.location.href = "/dashboard";
  }

  window.handleSubmit = handleSubmit;
</script>
</html>
