---
import HomeLayout from "../layout/HomeLayout.astro";
import "../styles/tailwind.css";
---

<HomeLayout active="perfil">
  <section class="mx-auto max-w-5xl px-6 py-10">
    <div class="rounded-3xl border border-white/10 bg-surface/60 p-8 shadow-2xl backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-glow">
      <p class="font-display text-sm font-bold uppercase tracking-[0.3em] text-primary">
        Perfil del manager
      </p>

      <h1 class="mt-3 font-display text-5xl font-extrabold uppercase italic text-text">
        Mi cuenta
      </h1>

      <!-- Datos del usuario -->
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5">
          <p class="text-sm uppercase text-textMuted">Nombre</p>
          <h2 id="profileName" class="mt-2 font-display text-3xl font-bold text-primary">
            Cargando...
          </h2>
        </div>

        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5">
          <p class="text-sm uppercase text-textMuted">Equipo</p>
          <h2 id="teamName" class="mt-2 font-display text-3xl font-bold text-text">
            Cargando...
          </h2>
        </div>

        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5 md:col-span-2">
          <p class="text-sm uppercase text-textMuted">Email</p>
          <h2 id="profileEmail" class="mt-2 text-xl font-bold text-text">
            Cargando...
          </h2>
        </div>
      </div>

      <!-- Resumen del equipo -->
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5">
          <p class="text-sm uppercase text-textMuted">Jugadores</p>
          <h2 id="playersCount" class="mt-2 font-display text-4xl font-bold text-primary">
            0
          </h2>
        </div>

        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5">
          <p class="text-sm uppercase text-textMuted">Gastado</p>
          <h2 id="moneySpent" class="mt-2 font-display text-4xl font-bold text-text">
            $0M
          </h2>
        </div>

        <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5">
          <p class="text-sm uppercase text-textMuted">Saldo</p>
          <h2 id="moneyLeft" class="mt-2 font-display text-4xl font-bold text-accent">
            $0M
          </h2>
        </div>
      </div>

      <!-- Plantilla -->
      <div class="mt-10">
        <h2 class="font-display text-3xl font-bold uppercase text-text">
          Mi plantilla
        </h2>

        <div id="playersList" class="mt-6 grid gap-4 md:grid-cols-2"></div>
      </div>

      <button
        id="logoutBtn"
        class="mt-10 w-full rounded-2xl bg-primary px-6 py-4 font-display text-lg font-bold uppercase text-black transition duration-300 hover:-translate-y-0.5 hover:scale-[1.01] hover:shadow-glow active:translate-y-0"
      >
        Cerrar sesión
      </button>
    </div>
  </section>

  <script is:inline>
    let noticeTimeout;

    function showNotice(type, title, message) {
      const previousNotice = document.querySelector("[data-profile-notice]");
      previousNotice?.remove();

      if (noticeTimeout) {
        window.clearTimeout(noticeTimeout);
      }

      const notice = document.createElement("div");
      notice.dataset.profileNotice = "true";
      notice.className =
        "fixed right-4 top-4 z-50 w-[min(360px,calc(100vw-32px))] rounded-2xl border border-outline-variant/30 bg-surface-container-high p-4 text-on-surface shadow-[0_18px_42px_rgba(0,0,0,0.45)]";
      notice.innerHTML = `
        <div class="flex gap-3">
          <span class="material-symbols-outlined mt-0.5 text-[22px] ${type === "error" ? "text-error" : "text-primary"}">
            ${type === "error" ? "error" : "check_circle"}
          </span>
          <div>
            <p class="font-label-bold text-label-bold">${title}</p>
            <p class="mt-1 text-sm text-on-surface-variant">${message}</p>
          </div>
        </div>
      `;

      document.body.appendChild(notice);
      noticeTimeout = window.setTimeout(() => notice.remove(), 3500);
    }

    async function loadProfile() {
      const response = await fetch("/api/user");
      const data = await response.json();

      if (!response.ok || !data.user) {
        window.location.href = "/login";
        return;
      }

      document.getElementById("profileName").textContent =
        data.user.user_metadata?.name || "Manager";

      document.getElementById("teamName").textContent =
        data.user.user_metadata?.team_name || "Sin equipo";

      document.getElementById("profileEmail").textContent =
        data.user.email || "";
    }

    async function loadResumen() {
      const response = await fetch("/api/resumen-equipo");
      const data = await response.json();

      const jugadores = data.jugadores || [];

      document.getElementById("playersCount").textContent = jugadores.length;
      document.getElementById("moneySpent").textContent = `$${data.gastado || 0}M`;
      document.getElementById("moneyLeft").textContent = `$${data.saldo || 0}M`;

      const playersList = document.getElementById("playersList");

      if (jugadores.length === 0) {
        playersList.innerHTML = `
          <div class="rounded-2xl border border-white/10 bg-background/40 p-6 transition duration-300 hover:border-primary/40 hover:bg-primary/5 md:col-span-2">
            <p class="text-textMuted">Todavía no tienes jugadores comprados.</p>
          </div>
        `;
        return;
      }

      playersList.innerHTML = jugadores.map((player) => `
        <div class="group flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-background/40 p-4 transition duration-300 hover:-translate-y-1 hover:border-primary/40 hover:bg-primary/5 hover:shadow-glow">
          
          <div class="flex items-center gap-4">
            <img
              src="${player.imagen_url || ""}"
              class="h-16 w-16 rounded-full object-cover ring-2 ring-white/10 transition duration-300 group-hover:ring-primary/60"
              alt="${player.nombre || "Jugador"}"
            />

            <div>
              <h3 class="font-bold text-text">
                ${player.nombre || "Jugador"}
              </h3>

              <p class="text-sm text-textMuted">
                ${player.posicion || ""}
              </p>
            </div>
          </div>

          <button
            class="rounded-lg bg-red-500 px-4 py-2 text-sm font-bold uppercase text-white transition duration-300 hover:-translate-y-0.5 hover:bg-red-400 hover:shadow-[0_0_24px_rgba(248,113,113,0.35)] active:translate-y-0"
            onclick="venderJugador('${player.id}')"
          >
            Vender
          </button>
        </div>
      `).join("");
      }
      async function venderJugador(jugadorId) {
        const response = await fetch("/api/vender", {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            jugadorId,
          }),
        });

        const data = await response.json();

        if (!response.ok) {
          showNotice("error", "No se pudo vender", data.error || "Error al vender");
          return;
        }

        window.location.reload();
      }
    document.getElementById("logoutBtn").addEventListener("click", async () => {
      await fetch("/api/logout", {
        method: "POST",
      });

      window.location.href = "/login";
    });

    loadProfile();
    loadResumen();
  </script>
</HomeLayout>
