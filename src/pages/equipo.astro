---
import CanchaEquipo from "../components/CanchaEquipo.jsx";
import HomeLayout from "../layout/HomeLayout.astro";
import { supabase } from "./lib/supabase";
export const prerender = false;

const token = Astro.cookies.get("sb-access-token")?.value;

if (!token) {
  return Astro.redirect("/login");
}

const {
  data: { user },
  error: userError,
} = await supabase.auth.getUser(token);

if (userError || !user) {
  return Astro.redirect("/login");
}

const { data: compras, error: comprasError } = await supabase
  .from("usuario_jugadores")
  .select(`
    id,
    id_jugador,
    jugadores (
      id,
      nombre,
      posicion,
      club,
      nacionalidad,
      edad,
      precio,
      imagen_url,
      goles,
      asistencias
    )
  `)
  .eq("id_usuario", user.id);

if (comprasError) {
  console.error("Error cargando jugadores comprados:", comprasError.message);
}

const positionMap = {
  Portero: "GK",
  POR: "GK",
  Defensa: "DEF",
  DEF: "DEF",
  Mediocampista: "MID",
  MED: "MID",
  Delantero: "FWD",
  DEL: "FWD",
};

function normalizarJugador(jugador) {
  const jugadorData = Array.isArray(jugador) ? jugador[0] : jugador;

  if (!jugadorData) {
    return null;
  }

  const posicion = jugadorData["posicion"];

  return {
    id: jugadorData["id"],
    name: jugadorData["nombre"],
    position: positionMap[posicion] ?? "MID",
    club: jugadorData["club"],
    nationality: jugadorData["nacionalidad"],
    age: jugadorData["edad"],
    value: jugadorData["precio"],
    image: jugadorData["imagen_url"],
    goals: jugadorData["goles"],
    assists: jugadorData["asistencias"],
  };
}

const jugadoresComprados = (compras ?? [])
  .map((compra) => normalizarJugador(compra.jugadores))
  .filter(Boolean);

const { data: perfil } = await supabase
  .from("perfil")
  .select("saldo")
  .eq("id", user.id)
  .single();

const presupuesto = perfil?.saldo ?? 0;
---

<HomeLayout title="Mi Equipo | World Cup Fantasy" active="equipo">
  <div class="flex-1 px-4 py-margin pb-32 md:px-margin md:pb-margin">
    <div class="mx-auto flex max-w-container-max flex-col gap-margin">
      <header class="flex flex-col gap-4 border-b border-outline-variant/20 pb-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-2 font-label-bold text-label-bold uppercase tracking-wider text-primary">
            World Cup Fantasy
          </p>

          <h1 class="font-headline-xl text-headline-xl text-on-surface">
            Mi Equipo
          </h1>

          <p class="mt-3 max-w-2xl font-body-lg text-body-lg text-on-surface-variant">
            Arma tu once titular y revisa el presupuesto disponible para completar la plantilla.
          </p>
        </div>

        <a
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-5 py-3 font-label-bold text-label-bold text-on-primary transition hover:bg-primary-fixed-dim"
          href="/dashboard"
        >
          <span class="material-symbols-outlined">storefront</span>
          Ir al mercado
        </a>
      </header>

      <CanchaEquipo
        client:load
        ownedPlayers={jugadoresComprados}
        budgetLeft={presupuesto}
      />
    </div>
  </div>
</HomeLayout>
