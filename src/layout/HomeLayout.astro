---
import "../styles/tailwind.css";

const { title = "World Cup Fantasy" } = Astro.props;
---

<html lang="es" class="dark">
   <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Mercado de Fichajes | World Cup Fantasy</title>
 
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lexend:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
 
    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
      }
 
      ::-webkit-scrollbar {
        width: 8px;
      }
 
      ::-webkit-scrollbar-track {
        background: #121414;
      }
 
      ::-webkit-scrollbar-thumb {
        background: #404944;
        border-radius: 4px;
      }
 
      ::-webkit-scrollbar-thumb:hover {
        background: #95d3ba;
      }
    </style>
  </head>

  <body class="bg-background text-on-surface min-h-screen flex selection:bg-primary selection:text-on-primary ">

   <nav class="hidden md:flex flex-col shrink-0 bg-surface-container dark:bg-surface-container-lowest h-screen w-64 fixed left-0 top-0 z-40 bg-surface-container/40 backdrop-blur-lg border-r border-outline-variant/20 shadow-xl gap-unit py-margin"> 
      <div class="px-margin mb-8">
        <div class="flex items-center gap-4 mb-2">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-tertiary-fixed-dim">
            <img
              alt="National Team Crest"
              class="w-full h-full object-cover"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6pPmaxSPTrw4yxLT1SUL8NFuJ7BzookcDBU6C-XC-WSt1vLXNRN8TV3A4OxrfXcIaJfzzq3z-On54HKzwEmQX-K8ORnh9cZYn_2rXRrXTE0IoIaVzGlKh8l0ymU1XUfscPF8s5PB08qCNi1_RFTu4H5MVdLCH4A9SjmyUdyRgG7HHVRCGueT_rU1VmMKF8X-54luxsbe5Y2MJ5I4E-eHLm4bkhCeif8mQj6AirjeINZO4trlSiDupPXeWw5VXcWg43Awqvtwf2Zk"
            />
          </div>
 
          <div>
            <h2 class="font-headline-md text-headline-md text-on-surface">
              Fantasy Football
            </h2>
           
          </div>
        </div>
 
       
      </div>
 
      <ul class="flex-1 overflow-y-auto w-full">
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-[0deg] transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">dashboard</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Dashboard
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="bg-primary-container text-on-primary-container rounded-lg flex items-center gap-4 px-4 py-3 mx-2 skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">storefront</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Mercado
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">leaderboard</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Equipo
            </span>
          </a>
        </li>
 
        <li>
          <a
            class="text-on-surface-variant flex items-center gap-4 px-4 py-3 mx-2 hover:bg-surface-variant/50 rounded-lg skew-x-[-5deg] hover:skew-x-0 transition-all duration-200"
            href="#"
          >
            <span class="material-symbols-outlined">person</span>
            <span class="skew-x-[5deg] block font-label-bold text-label-bold">
              Perfil
            </span>
          </a>
        </li>
      </ul>
    </nav> 
    <main class="flex-1 flex flex-col min-h-screen w-full md:pl-64 relative bg-[radial-gradient(ellipse_at_top,var(--tw-gradient-stops))] from-surface-variant/20 via-background to-background">
        <slot />
    </main>

  </body>
</html>